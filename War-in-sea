<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>War Beneath the Sea</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #111;
            color: white;
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }
        canvas {
            background-color: #004466; /* Deep sea blue */
            border: 4px solid #fff;
            box-shadow: 0 0 15px rgba(0, 150, 255, 0.5);
        }
        .instructions {
            margin-top: 15px;
            text-align: center;
        }
    </style>
</head>
<body>

    <h1>War Beneath the Sea</h1>
    <canvas id="gameCanvas" width="800" height="400"></canvas>
    
    <div class="instructions">
        <p><strong>Up / Down Arrows:</strong> Move &nbsp;&nbsp;|&nbsp;&nbsp; <strong>Spacebar:</strong> Shoot</p>
        <p>Refresh the page to restart after Game Over.</p>
    </div>

    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");

        // Game State
        let isGameOver = false;
        let score = 0;
        let frameCount = 0;

        // Input Tracking
        const keys = { ArrowUp: false, ArrowDown: false };

        window.addEventListener("keydown", (e) => {
            if (keys.hasOwnProperty(e.code)) keys[e.code] = true;
            if (e.code === "Space" && !isGameOver) shootBullet();
        });

        window.addEventListener("keyup", (e) => {
            if (keys.hasOwnProperty(e.code)) keys[e.code] = false;
        });

        // --- Game Objects ---

        // The Sea Hero
        const hero = {
            x: 50,
            y: 200,
            width: 30,
            height: 30,
            speed: 5,
            color: "#00FFcc" // Cyan square
        };

        // Arrays for entities
        let bullets = [];
        let sharks = [];
        let bubbles = [];

        // Setup initial background bubbles for the loop
        for (let i = 0; i < 30; i++) {
            bubbles.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                radius: Math.random() * 4 + 1,
                speed: Math.random() * 2 + 1
            });
        }

        // --- Core Functions ---

        function shootBullet() {
            bullets.push({
                x: hero.x + hero.width,
                y: hero.y + hero.height / 2 - 2,
                width: 15,
                height: 4,
                speed: 8,
                color: "yellow"
            });
        }

        function spawnShark() {
            // Random Y position, ensuring it stays within the water
            const sharkY = Math.random() * (canvas.height - 40 - 30); 
            sharks.push({
                x: canvas.width,
                y: sharkY,
                width: 40,
                height: 25,
                speed: Math.random() * 3 + 2,
                color: "#555" // Gray shark boxes
            });
        }

        // --- Update Logic ---

        function update() {
            if (isGameOver) return;

            frameCount++;

            // Move Hero
            if (keys.ArrowUp && hero.y > 0) {
                hero.y -= hero.speed;
            }
            if (keys.ArrowDown && hero.y < canvas.height - hero.height - 40) { // 40 is sand height
                hero.y += hero.speed;
            }

            // Move Background Bubbles (Looping effect)
            bubbles.forEach(bubble => {
                bubble.x -= bubble.speed;
                if (bubble.x < -10) {
                    bubble.x = canvas.width + 10;
                    bubble.y = Math.random() * canvas.height;
                }
            });

            // Move Bullets
            bullets.forEach((b, index) => {
                b.x += b.speed;
                if (b.x > canvas.width) bullets.splice(index, 1);
            });

            // Spawn and Move Sharks
            if (frameCount % 60 === 0) { // Spawn roughly every 1 second (at 60fps)
                spawnShark();
            }

            sharks.forEach((shark, sIndex) => {
                shark.x -= shark.speed;

                // Shark off-screen cleanup
                if (shark.x + shark.width < 0) {
                    sharks.splice(sIndex, 1);
                }

                // Collision: Shark hits Hero
                if (
                    hero.x < shark.x + shark.width &&
                    hero.x + hero.width > shark.x &&
                    hero.y < shark.y + shark.height &&
                    hero.y + hero.height > shark.y
                ) {
                    isGameOver = true;
                }

                // Collision: Bullet hits Shark
                bullets.forEach((bullet, bIndex) => {
                    if (
                        bullet.x < shark.x + shark.width &&
                        bullet.x + bullet.width > shark.x &&
                        bullet.y < shark.y + shark.height &&
                        bullet.y + bullet.height > shark.y
                    ) {
                        // Destroy both
                        sharks.splice(sIndex, 1);
                        bullets.splice(bIndex, 1);
                        score += 10;
                    }
                });
            });
        }

        // --- Drawing Logic ---

        function draw() {
            // Clear Canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Draw Looping Background (Bubbles & Sand)
            ctx.fillStyle = "rgba(255, 255, 255, 0.3)";
            bubbles.forEach(bubble => {
                ctx.beginPath();
                ctx.arc(bubble.x, bubble.y, bubble.radius, 0, Math.PI * 2);
                ctx.fill();
            });

            ctx.fillStyle = "#c2b280"; // Sand color
            ctx.fillRect(0, canvas.height - 40, canvas.width, 40);

            // Draw Hero
            ctx.fillStyle = hero.color;
            ctx.fillRect(hero.x, hero.y, hero.width, hero.height);

            // Draw Bullets
            bullets.forEach(b => {
                ctx.fillStyle = b.color;
                ctx.fillRect(b.x, b.y, b.width, b.height);
            });

            // Draw Sharks
            sharks.forEach(shark => {
                ctx.fillStyle = shark.color;
                ctx.fillRect(shark.x, shark.y, shark.width, shark.height);
                
                // Add a tiny eye for the basic shark
                ctx.fillStyle = "red";
                ctx.fillRect(shark.x + 5, shark.y + 5, 4, 4);
            });

            // Draw Score
            ctx.fillStyle = "white";
            ctx.font = "20px Arial";
            ctx.fillText("Score: " + score, 20, 30);

            // Draw Game Over Screen
            if (isGameOver) {
                ctx.fillStyle = "rgba(0, 0, 0, 0.7)";
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = "red";
                ctx.font = "50px Arial";
                ctx.textAlign = "center";
                ctx.fillText("GAME OVER", canvas.width / 2, canvas.height / 2);
                
                ctx.fillStyle = "white";
                ctx.font = "20px Arial";
                ctx.fillText("Final Score: " + score, canvas.width / 2, canvas.height / 2 + 40);
                ctx.fillText("Press F5 to Restart", canvas.width / 2, canvas.height / 2 + 80);
            }
        }

        // --- Game Loop ---

        function gameLoop() {
            update();
            draw();
            if (!isGameOver) {
                requestAnimationFrame(gameLoop);
            }
        }

        // Start the game
        gameLoop();
    </script>
</body>
</html>

