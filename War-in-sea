<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>War Beneath the Sea - Image Version</title>
    <style>
        body { margin: 0; background: #222; color: white; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; overflow: hidden; }
        canvas { background-color: #004466; border: 4px solid #fff; }
        .ui { margin-top: 10px; }
    </style>
</head>
<body>

    <h1>War Beneath the Sea</h1>
    <canvas id="gameCanvas" width="800" height="400"></canvas>
    <div class="ui">Arrows to Move | Space to Shoot</div>

    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");

        // --- 1. LOAD IMAGES ---
        let imagesLoaded = 0;
        const totalImages = 2;

        const bgImg = new Image();
        bgImg.src = "https://images.unsplash.com/photo-1582967788606-a171c1080cb0?q=80&w=800&auto=format&fit=crop"; // Sea Background

        const heroImg = new Image();
        heroImg.src = "https://cdn-icons-png.flaticon.com/512/2611/2611152.png"; // Hero Submarine/Fish PNG

        function imageLoaded() {
            imagesLoaded++;
            if (imagesLoaded === totalImages) {
                gameLoop(); // Start game only when all images are ready
            }
        }

        bgImg.onload = imageLoaded;
        heroImg.onload = imageLoaded;

        // --- 2. GAME VARIABLES ---
        let isGameOver = false;
        let score = 0;
        let frameCount = 0;
        let bgX = 0;

        const hero = { x: 50, y: 180, w: 60, h: 40, speed: 6 };
        let bullets = [];
        let sharks = [];
        const keys = { ArrowUp: false, ArrowDown: false };

        window.addEventListener("keydown", e => {
            if (keys.hasOwnProperty(e.code)) keys[e.code] = true;
            if (e.code === "Space" && !isGameOver) shoot();
        });
        window.addEventListener("keyup", e => {
            if (keys.hasOwnProperty(e.code)) keys[e.code] = false;
        });

        function shoot() {
            bullets.push({ x: hero.x + hero.w, y: hero.y + hero.h / 2, w: 10, h: 4 });
        }

        // --- 3. UPDATE LOGIC ---
        function update() {
            if (isGameOver) return;

            // Background Loop Logic
            bgX -= 2;
            if (bgX <= -canvas.width) bgX = 0;

            // Hero Movement
            if (keys.ArrowUp && hero.y > 0) hero.y -= hero.speed;
            if (keys.ArrowDown && hero.y < canvas.height - hero.h) hero.y += hero.speed;

            // Bullets Logic
            bullets.forEach((b, i) => {
                b.x += 8;
                if (b.x > canvas.width) bullets.splice(i, 1);
            });

            // Shark Logic
            frameCount++;
            if (frameCount % 70 === 0) {
                sharks.push({ x: canvas.width, y: Math.random() * (canvas.height - 40), w: 50, h: 30, speed: 3 + Math.random() * 2 });
            }

            sharks.forEach((s, si) => {
                s.x -= s.speed;
                
                // Collision: Shark hits Hero
                if (hero.x < s.x + s.w && hero.x + hero.w > s.x && hero.y < s.y + s.h && hero.y + hero.h > s.y) {
                    isGameOver = true;
                }

                // Collision: Bullet hits Shark
                bullets.forEach((b, bi) => {
                    if (b.x < s.x + s.w && b.x + b.w > s.x && b.y < s.y + s.h && b.y + b.h > s.y) {
                        sharks.splice(si, 1);
                        bullets.splice(bi, 1);
                        score += 10;
                    }
                });

                if (s.x + s.w < 0) sharks.splice(si, 1);
            });
        }

        // --- 4. DRAW LOGIC ---
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Layer 1: Looping Background
            ctx.drawImage(bgImg, bgX, 0, canvas.width, canvas.height);
            ctx.drawImage(bgImg, bgX + canvas.width, 0, canvas.width, canvas.height);

            // Layer 2: Hero Image
            ctx.drawImage(heroImg, hero.x, hero.y, hero.w, hero.h);

            // Layer 3: Bullets (Simple rectangles for better visibility)
            ctx.fillStyle = "yellow";
            bullets.forEach(b => ctx.fillRect(b.x, b.y, b.w, b.h));

            // Layer 4: Sharks (Simple rectangles for low quality feel)
            ctx.fillStyle = "grey";
            sharks.forEach(s => {
                ctx.fillRect(s.x, s.y, s.w, s.h);
                ctx.fillStyle = "red";
                ctx.fillRect(s.x + 5, s.y + 5, 5, 5); // eye
                ctx.fillStyle = "grey";
            });

            // Layer 5: UI
            ctx.fillStyle = "white";
            ctx.font = "20px Arial";
            ctx.fillText("Score: " + score, 20, 30);

            if (isGameOver) {
                ctx.fillStyle = "rgba(0,0,0,0.8)";
                ctx.fillRect(0,0, canvas.width, canvas.height);
                ctx.fillStyle = "red";
                ctx.textAlign = "center";
                ctx.fillText("GAME OVER - PRESS F5", canvas.width/2, canvas.height/2);
            }
        }

        function gameLoop() {
            update();
            draw();
            if (!isGameOver) requestAnimationFrame(gameLoop);
        }
    </script>
</body>
</html>

